# Stage 1: Build
FROM rust:1.82-slim-bookworm AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY api/ ./

RUN cargo build --release

# Stage 2: Runtime
FROM gcr.io/distroless/cc-debian12

COPY --from=builder /app/target/release/hestia-api /usr/local/bin/hestia-api

ENTRYPOINT ["/usr/local/bin/hestia-api"]
