# Hestia Environment Configuration
# Copy to /var/lib/hestia/hestia.env and fill in values.

# PostgreSQL
POSTGRES_DB=hestia
POSTGRES_USER=hestia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Database connection string (used by hestia-api)
DATABASE_URL=postgres://hestia:CHANGE_ME_STRONG_PASSWORD@hestia-postgres:5432/hestia

# Session secret for cookie signing (generate with: openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
